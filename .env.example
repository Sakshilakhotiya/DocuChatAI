HUGGINGFACEHUB_API_KEY=your-huggingface-api-key-here

# Optional model overrides
HF_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=llama3-8b-8192

# Optional: set to 'development' or 'production'
NODE_ENV=development

# Client configuration
VITE_API_BASE_URL=http://localhost:5000/api
